OPENCLAW_GATEWAY_TOKEN=your auth token

# 声纹验证相似度阈值；越高越严格，越低越容易通过。默认 0.65。
VOICE_ASSISTANT_SPEAKER_THRESHOLD=0.65

# 连续对话空闲多久后自动退回待机，单位秒。默认 15。
VOICE_ASSISTANT_IDLE_TIMEOUT_SECONDS=15

# 音频回调队列最大缓存帧数；过小可能丢音频，过大可能增加延迟。默认 100。
VOICE_ASSISTANT_AUDIO_QUEUE_MAXSIZE=100

# 是否监听默认输入设备切换；切换麦克风/耳机后自动重建输入流。默认 true。
VOICE_ASSISTANT_AUDIO_DEVICE_WATCH_ENABLED=true

# 默认输入设备轮询间隔，单位秒；越小切换响应越快。默认 1.5。
VOICE_ASSISTANT_AUDIO_DEVICE_POLL_INTERVAL_SECONDS=1.5

# macOS 系统级 AEC：消除扬声器播放的整机声音（含其他应用）。默认启用；
# 启用前运行 scripts/build_macos_system_audio_capture.sh，并授予“屏幕与系统音频录制”权限。
VOICE_ASSISTANT_SYSTEM_AEC_ENABLED=true

# 系统输出到麦克风的声学延迟；本机实验最佳约为 100ms。
VOICE_ASSISTANT_SYSTEM_AEC_DELAY_MS=100

# ScreenCaptureKit 系统参考相对实时麦克风的交付延迟；本机实测约 80ms。
VOICE_ASSISTANT_SYSTEM_AEC_REFERENCE_DELIVERY_MS=80

# AEC 诊断日志间隔；0 表示正式运行时关闭。
VOICE_ASSISTANT_SYSTEM_AEC_DIAGNOSTICS_SECONDS=0

# KWS 提前命中时用于活体/声纹的最低样本长度；不足则延后到完整话语验证。
VOICE_ASSISTANT_EARLY_WAKE_MIN_SECONDS=2.5

# 媒体播放时，活体通过后用于声纹的连续近端窗口长度。
VOICE_ASSISTANT_MEDIA_SPEAKER_WINDOW_SECONDS=2.0

# 可选：系统音频采集 helper 的绝对路径；留空时使用 native/macos_system_audio_capture。
# VOICE_ASSISTANT_SYSTEM_AEC_HELPER=/absolute/path/to/macos_system_audio_capture

# 流式识别无新语音多久后把当前文本视为一句话结束，单位秒。默认 1.5。
VOICE_ASSISTANT_SILENCE_DURATION_SECONDS=1.5

# TTS 合成时每批最多包含多少句；越小首句更快，越大合成次数更少。默认 4。
VOICE_ASSISTANT_TTS_MAX_SENTENCES=4

# 是否启用被动活体检测实验；复用唤醒前音频，不增加交互步骤。默认 true。
VOICE_ASSISTANT_LIVENESS_ENABLED=true

# 是否强制拦截活体检测失败的唤醒。默认 true。
VOICE_ASSISTANT_LIVENESS_ENFORCE=true

# 活体检测通过阈值；分数越高越像真人当场说话。默认 0.6。
VOICE_ASSISTANT_LIVENESS_THRESHOLD=0.6

# 活体检测 ONNX 模型路径，相对项目根目录；模型缺失时软失败放行。
VOICE_ASSISTANT_LIVENESS_MODEL=models/aasist-l.onnx

# 是否启用本机媒体播放门禁；用于识别电脑本机正在播放媒体时的重放唤醒。默认 true。
VOICE_ASSISTANT_MEDIA_WAKE_GUARD_ENABLED=true

# 是否强制拦截“唤醒瞬间本机正在播放媒体”的情况；AEC 健康时允许继续验证。默认 true。
VOICE_ASSISTANT_MEDIA_WAKE_GUARD_ENFORCE=true
