OPENCLAW_GATEWAY_TOKEN=your auth token

# 声纹验证相似度阈值；越高越严格，越低越容易通过。默认 0.55。
VOICE_ASSISTANT_SPEAKER_THRESHOLD=0.55

# 连续对话空闲多久后自动退回待机，单位秒。默认 30。
VOICE_ASSISTANT_IDLE_TIMEOUT_SECONDS=30

# 音频回调队列最大缓存帧数；过小可能丢音频，过大可能增加延迟。默认 100。
VOICE_ASSISTANT_AUDIO_QUEUE_MAXSIZE=100

# 流式识别无新语音多久后把当前文本视为一句话结束，单位秒。默认 1.5。
VOICE_ASSISTANT_SILENCE_DURATION_SECONDS=1.5

# TTS 合成时每批最多包含多少句；越小首句更快，越大合成次数更少。默认 4。
VOICE_ASSISTANT_TTS_MAX_SENTENCES=4

# 是否启用被动活体检测实验；复用唤醒前音频，不增加交互步骤。默认 true。
VOICE_ASSISTANT_LIVENESS_ENABLED=true

# 是否强制拦截活体检测失败的唤醒；实验期建议 false，只记录分数不改变体验。默认 false。
VOICE_ASSISTANT_LIVENESS_ENFORCE=false

# 活体检测通过阈值；分数越高越像真人当场说话。默认 0.5。
VOICE_ASSISTANT_LIVENESS_THRESHOLD=0.5

# 活体检测 ONNX 模型路径，相对项目根目录；模型缺失时软失败放行。
VOICE_ASSISTANT_LIVENESS_MODEL=models/aasist-l.onnx

# 是否启用本机媒体播放门禁；用于识别电脑本机正在播放媒体时的重放唤醒。默认 true。
VOICE_ASSISTANT_MEDIA_WAKE_GUARD_ENABLED=true

# 是否强制拦截“唤醒瞬间本机正在播放媒体”的情况；实验期建议先 false。默认 false。
VOICE_ASSISTANT_MEDIA_WAKE_GUARD_ENFORCE=false
