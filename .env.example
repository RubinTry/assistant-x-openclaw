OPENCLAW_GATEWAY_TOKEN=your auth token

# 声纹验证相似度阈值；越高越严格，越低越容易通过。默认 0.55。
VOICE_ASSISTANT_SPEAKER_THRESHOLD=0.55

# 连续对话空闲多久后自动退回待机，单位秒。默认 30。
VOICE_ASSISTANT_IDLE_TIMEOUT_SECONDS=30

# 音频回调队列最大缓存帧数；过小可能丢音频，过大可能增加延迟。默认 100。
VOICE_ASSISTANT_AUDIO_QUEUE_MAXSIZE=100

# 流式识别无新语音多久后把当前文本视为一句话结束，单位秒。默认 1.5。
VOICE_ASSISTANT_SILENCE_DURATION_SECONDS=1.5

# TTS 合成时每批最多包含多少句；越小首句更快，越大合成次数更少。默认 4。
VOICE_ASSISTANT_TTS_MAX_SENTENCES=4

